# Discord user token — get from browser DevTools:
#   1. Open Discord in browser → F12 → Network tab
#   2. Navigate or send a message → find any request to discord.com/api
#   3. Copy the "Authorization" header value
DISCORD_TOKEN=your_user_token_here

# Guild (server) ID for the IMC Prosperity Discord
GUILD_ID=1234567890

# Channel IDs to monitor (comma-separated)
# Enable Developer Mode in Discord: Settings → Advanced → Developer Mode
# Right-click channel → Copy Channel ID
WATCH_CHANNELS=123456789,987654321

# High-priority channels (strategy/code channels) — get 1.2x score multiplier
HIGH_PRIORITY_CHANNELS=

# Low-priority channels (off-topic) — get 0.6x score multiplier
LOW_PRIORITY_CHANNELS=

# Current competition round (0 = tutorial/pre-round)
CURRENT_ROUND=0

# Known products (comma-separated, extend as rounds drop)
KNOWN_PRODUCTS=EMERALDS,TOMATOES

# Relevance threshold (0-100, messages below this are discarded)
RELEVANCE_THRESHOLD=20

# Backfill limit (max messages per channel when using --backfill)
BACKFILL_LIMIT=2000

# Google Gemini API key — for strategy summarization
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
